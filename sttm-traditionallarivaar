javascript: (function () {
    function formatPage() {
        document.querySelector("#nav-bar").style.display = "none";
        document.querySelector(".breadcrumb").style.display = "none";
        document.querySelector("#controls-menu").style.display = "none";
        document.querySelector(".pagination-ang").style.display = "none";
        document.querySelector(".footer-background").style.display = "none";
        document.querySelector("#freshworks-container").style.display = "none";
        document.querySelector(".floatingActions").style.display = "none";
        const contentRoot = document.querySelector("#content-root");
        contentRoot.style.maxWidth = "100%";
        const shabad = document.querySelector("#shabad");
        shabad.style.padding = "84px 10px 5px 10px";
        shabad.style.display = "block";
        shabad.style.lineBreak = "anywhere";
        shabad.style.height = "1500px";
        const topButtonRow = document.querySelector(".shabad-container");
        topButtonRow.style.position = "fixed";
        topButtonRow.style.marginTop = "-15px";
        const topButtonRowNew = document.querySelector("#metadata");
        topButtonRowNew.children[1].children[1].style.display = "none";
        topButtonRowNew.style.padding = "0px";
        topButtonRowNew.style.margin = "0rem 2rem 0rem 2rem";
        topButtonRowNew.style.position = "fixed";
        let shabadPage = document.querySelector(".shabadPage");
        if (!shabadPage) {
            shabadPage = document.createElement("div");
            shabadPage.classList.add("shabadPage");
            shabadPage.style.padding = "5px 10px 5px 2px";
            shabad.appendChild(shabadPage);
        } else {
            shabadPage.innerHTML = "";
        }
		let tukList = [];
		let countOfIkOankarOnPage = 0;
        document.querySelectorAll(".mixed-view-baani-wrapper").forEach((minViewBaniWrapper) => {
            const newDiv = document.createElement("span");
            let wordsDiv;
            minViewBaniWrapper.querySelectorAll(".unicode").forEach((unicode) => {
                if (unicode.children.length > 0) {
                    let containWords = false;
					let containIkOankar = false;
                    wordsDiv = document.createElement("span");
                    wordsDiv.classList.add("tuk");
                    wordsDiv.style.fontFamily = "AnmolUni";
                    wordsDiv.style.fontSize = "40px";
                    wordsDiv.style.paddingTop = "10px";
                    wordsDiv.style.paddingBottom = "5px";
                    for (let word of unicode.children) {
                        containWords = true;
                        const wordDiv = document.createElement("span");
						wordDiv.textContent = word.textContent.trim();
                        if (word.textContent.trim() == "ੴ") {
							countOfIkOankarOnPage++;
							containIkOankar = true;
                            wordDiv.style.fontWeight = "bold";
                            wordDiv.style.color = "crimson";
                        }
                        wordsDiv.appendChild(wordDiv);
                    }
                    if (containWords) newDiv.appendChild(wordsDiv);
                }
            });
            const tooltip = minViewBaniWrapper.cloneNode(true);
            tooltip.style.display = "none";
            tooltip.style.zIndex = 999;
            tooltip.style.position = "absolute";
            tooltip.style.backgroundColor = "#ddd";
            tooltip.style.transform = "translateX(-50%)";
            tooltip.style.left = "50%";
            tooltip.style.width = "1000px";
            tooltip.style.padding = "25px 25px 25px 25px";
            newDiv.appendChild(tooltip);
            minViewBaniWrapper.style.display = "none";
            // shabadPage.appendChild(newDiv);
			
			const viewportWidth = window.innerWidth;
			const viewportHeight = window.innerHeight;

            newDiv.addEventListener("click", function (e) {
				if (wordsDiv) {
					if (wordsDiv.style.color != 'red') {
						wordsDiv.style.color = 'red';
					  }
					else {
						wordsDiv.style.color = '#03669b';
					}
				}
                if (newDiv.children[1].style.display == "none") {
                    newDiv.children[1].style.display = "";
                } else {
                    newDiv.children[1].style.display = "none";
                }
				// console.log('mouseclick Y coordinates e.clientY :::' + e.clientY);
				// console.log('tooltip height tooltip.offsetHeight :::' + tooltip.offsetHeight);
				// console.log('tooltip height newDiv.children[1].offsetHeight ::' + newDiv.children[1].offsetHeight);
				console.log('viewportHeight ::' + viewportHeight);
				if (((e.clientY + 50 + newDiv.children[1].offsetHeight) > viewportHeight)  &&  ((e.clientY - newDiv.children[1].offsetHeight) > 0)) {
					newDiv.children[1].style.top = (e.clientY - 50 - newDiv.children[1].offsetHeight) + 'px';
				}
				else {
					newDiv.children[1].style.top = (e.clientY + 50) + 'px';
				}
				console.log('newDiv.children[1].style.top :: ' + newDiv.children[1].style.top);
            });
            if (wordsDiv) {
                wordsDiv.addEventListener("mouseenter", function () {
                    wordsDiv.style.backgroundColor = "wheat";
                });
                wordsDiv.addEventListener("mouseleave", function () {
                    wordsDiv.style.backgroundColor = "";
                });
            }
			tukList.push(newDiv);
        });
		
		for (let i = 0; i < tukList.length; i++) {
		// tukList.forEach((newDiv) => {
			
			let newDiv = tukList[i];
			// console.log(newDiv.textContent);
			// console.log(JSON.stringify(newDiv));
			
			shabadPage.appendChild(newDiv);

			const regex = /\|\|\d+\|\|\d+\|\|/;
			// Check if current tuk is shabad ending indicated by presence of ||<number>||<number>||
			if (regex.test(newDiv.innerHTML)) {
				console.log('Pattern found!!');
				let nextUpIkOankar = false;
				
				// If yes, then check next 5 tuks to see if ੴ is present in them.
				for (let j = 1; j < 5; j++) {
					if (i+j < tukList.length) {
						nextUpIkOankar = nextUpIkOankar || tukList[i+j].innerHTML.includes('ੴ');
					}
				}
				
				// if ੴ is present, then add a new line.
				if (nextUpIkOankar) shabadPage.appendChild(document.createElement("p"));
			}
		} // );
    }
    formatPage();
    const button = document.createElement("button");
    button.classList.add("formatPageButton");
    button.innerText = "Format Page";
    Object.assign(button.style, {
        position: "fixed",
        top: "16px",
        right: "120px",
        zIndex: "9999",
        padding: "10px 15px",
        backgroundColor: "#007BFF",
        color: "#fff",
        border: "none",
        borderRadius: "5px",
        fontSize: "14px",
        cursor: "pointer",
        boxShadow: "0 4px 6px rgba(0,0,0,0.1)",
    });
    document.body.appendChild(button);
    button.addEventListener("click", function () {
        formatPage();
    });
    document.addEventListener("keydown", function (event) {
        if (event.key === "ArrowRight" || event.key === "k") {
            document.querySelectorAll(".shabad-nav a")[1].click();
        }
        if (event.key === "ArrowLeft" || event.key === "h") {
            document.querySelectorAll(".shabad-nav a")[0].click();
        }
        if (event.key === "j" || event.key === "J") {
            document.querySelector(".formatPageButton").click();
        }
    });
})();
